# Railway API environment variables (Railway dashboard → finflow-api → Variables)

ConnectionStrings__Db=Host=YOUR_NEON_HOST;Database=neondb;Username=neondb_owner;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
ASPNETCORE_ENVIRONMENT=Production
JwtSettings__SecretKey=generate-a-secret-at-least-32-characters-long
JwtSettings__Issuer=finflow.app
JwtSettings__Audience=finflow.app

# Set after Vercel deploy (your frontend URL, no trailing slash):
Cors__AllowedOrigins__0=https://your-app.vercel.app

# Neon postgresql:// URI (from Neon dashboard):
# postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
